---
// src/pages/tag/[tag].astro — Danh sách bài viết theo 1 tag cụ thể
import { getCollection } from "astro:content";
import BoCucMacDinh from "../../bo_cuc/BoCucMacDinh.astro";
import TheBaiViet from "../../thanh_phan/TheBaiViet.astro";

export async function getStaticPaths() {
  const tatCaBaiViet = await getCollection("bai_viet", ({ data }) => !data.nhap);
  const tatCaTag = Array.from(new Set(tatCaBaiViet.flatMap((bai) => bai.data.tags)));
  return tatCaTag.map((tag) => ({
    params: { tag },
    props: {
      baiTheoTag: tatCaBaiViet.filter((bai) => bai.data.tags.includes(tag)),
    },
  }));
}

const { tag } = Astro.params;
const { baiTheoTag } = Astro.props;
---

<BoCucMacDinh tieuDeTrang={`Bài viết gắn tag #${tag}`}>
  <section class="border-b py-20" style="border-color:var(--border)">
    <div class="container mx-auto max-w-6xl px-7">
      <p class="uppercase tracking-[0.14em] text-[0.78rem] mb-3" style="color:var(--text-mo)">Danh mục</p>
      <h1>#{tag}</h1>
    </div>
  </section>
  <section class="py-20">
    <div class="container mx-auto max-w-6xl px-7 grid gap-11 gap-x-7 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {baiTheoTag.map((bai) => <TheBaiViet bai={bai} />)}
    </div>
  </section>
</BoCucMacDinh>
