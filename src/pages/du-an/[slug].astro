---
// src/pages/du-an/[slug].astro — Trang chi tiết 1 dự án
// Tương đương _bocuctrang/trangweb.html của bản gốc.
import { getCollection, render } from "astro:content";
import BoCucMacDinh from "../../bo_cuc/BoCucMacDinh.astro";

export async function getStaticPaths() {
  const tatCaDuAn = await getCollection("du_an");
  return tatCaDuAn.map((duAn) => ({
    params: { slug: duAn.id },
    props: { duAn },
  }));
}

const { duAn } = Astro.props;
const { Content } = await render(duAn);
---

<BoCucMacDinh tieuDeTrang={duAn.data.tieu_de} moTaTrang={duAn.data.mo_ta_ngan} anhTrang={duAn.data.anh_dai_dien}>
  <section class="border-b py-20" style="border-color:var(--border)">
    <div class="container mx-auto max-w-6xl px-7">
      <h1>{duAn.data.tieu_de}</h1>
      <p class="text-[1.1rem] max-w-[56ch]" style="color:var(--text-mo)">{duAn.data.mo_ta_ngan}</p>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto max-w-6xl px-7 van-ban-dai">
      <Content />
      <div class="flex flex-wrap gap-2 my-4">
        {
          duAn.data.cong_nghe.map((cn) => (
            <span class="text-[0.85rem] border rounded-full px-3 py-1.5" style="border-color:var(--border);color:var(--text-mo)">
              {cn}
            </span>
          ))
        }
      </div>
      <p class="flex gap-2.5 items-center mt-7">
        {
          duAn.data.link_github && (
            <a
              class="nut inline-flex items-center gap-1.5 border rounded-sm px-3.5 py-1.5 text-[0.88rem] no-underline"
              style="border-color:var(--border);color:var(--text)"
              href={duAn.data.link_github}
              target="_blank"
              rel="noopener"
            >
              GitHub
            </a>
          )
        }
        {
          duAn.data.link_demo && (
            <a
              class="nut inline-flex items-center gap-1.5 border rounded-sm px-3.5 py-1.5 text-[0.88rem] no-underline"
              style="border-color:var(--border);color:var(--text)"
              href={duAn.data.link_demo}
              target="_blank"
              rel="noopener"
            >
              Xem demo
            </a>
          )
        }
      </p>
    </div>
  </section>
</BoCucMacDinh>
