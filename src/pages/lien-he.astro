---
// src/pages/lien-he.astro
import BoCucMacDinh from "../bo_cuc/BoCucMacDinh.astro";
import { cauHinh } from "../cau_hinh/trang_web";

const kenhLienLac = [
  { ten: "Email", href: `mailto:${cauHinh.email}`, ngoai: false },
  { ten: "GitHub", href: cauHinh.mang_xa_hoi.github, ngoai: true },
  { ten: "Facebook", href: cauHinh.mang_xa_hoi.facebook, ngoai: true },
  { ten: "X (Twitter)", href: cauHinh.mang_xa_hoi.twitter, ngoai: true },
  { ten: "LinkedIn", href: cauHinh.mang_xa_hoi.linkedin, ngoai: true },
];
---

<BoCucMacDinh tieuDeTrang="Liên hệ">
  <section class="border-b py-20" style="border-color:var(--border)">
    <div class="container mx-auto max-w-6xl px-7">
      <p class="uppercase tracking-[0.14em] text-[0.78rem] mb-3" style="color:var(--text-mo)">Liên hệ</p>
      <h1>Liên hệ</h1>
      <p class="text-[1.1rem] max-w-[56ch]" style="color:var(--text-mo)">
        Có góp ý, câu hỏi, hay chỉ muốn trò chuyện về Đạo giáo và kỹ thuật — cứ nhắn cho tôi.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto max-w-6xl px-7 grid gap-20 grid-cols-1 sm:grid-cols-2">
      <div>
        <h2>Kênh liên lạc</h2>
        <ul class="list-none m-0 p-0">
          {
            kenhLienLac.map((kenh) => (
              <li class="border-b" style="border-color:var(--border)">
                <a
                  class="flex items-center justify-between py-3.5 no-underline"
                  style="color:var(--text)"
                  href={kenh.href}
                  target={kenh.ngoai ? "_blank" : undefined}
                  rel={kenh.ngoai ? "noopener" : undefined}
                >
                  {kenh.ten} <span aria-hidden="true">↗</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h2>Gửi tin nhắn</h2>
        <p class="text-[0.95rem]" style="color:var(--text-mo)">
          Đây là biểu mẫu tĩnh minh họa — trang không có backend, vui lòng dùng email để liên hệ trực tiếp.
        </p>
        <form action={`mailto:${cauHinh.email}`} method="post" enctype="text/plain">
          <div class="mb-7">
            <label class="block text-[0.88rem] mb-1.5" style="color:var(--text-mo)" for="ho-ten">Họ tên</label>
            <input
              id="ho-ten"
              name="ho_ten"
              type="text"
              autocomplete="name"
              class="w-full text-[1rem] border rounded-sm px-3.5 py-2.5"
              style="background:var(--bg-noi);border-color:var(--border);color:var(--text)"
            />
          </div>
          <div class="mb-7">
            <label class="block text-[0.88rem] mb-1.5" style="color:var(--text-mo)" for="thu-dien-tu">Email</label>
            <input
              id="thu-dien-tu"
              name="email"
              type="email"
              autocomplete="email"
              class="w-full text-[1rem] border rounded-sm px-3.5 py-2.5"
              style="background:var(--bg-noi);border-color:var(--border);color:var(--text)"
            />
          </div>
          <div class="mb-7">
            <label class="block text-[0.88rem] mb-1.5" style="color:var(--text-mo)" for="noi-dung">Nội dung</label>
            <textarea
              id="noi-dung"
              name="noi_dung"
              rows="5"
              class="w-full text-[1rem] border rounded-sm px-3.5 py-2.5 resize-y"
              style="background:var(--bg-noi);border-color:var(--border);color:var(--text)"
            ></textarea>
          </div>
          <button
            class="nut inline-flex items-center gap-1.5 border rounded-sm px-3.5 py-1.5 text-[0.88rem] cursor-pointer"
            style="border-color:var(--border);color:var(--text);background:none"
            type="submit"
          >
            Gửi qua email
          </button>
        </form>
      </div>
    </div>
  </section>
</BoCucMacDinh>
