---
// src/pages/sach/[slug].astro — Trang chi tiết 1 cuốn sách
import { getCollection, render } from "astro:content";
import BoCucMacDinh from "../../bo_cuc/BoCucMacDinh.astro";

export async function getStaticPaths() {
  const tatCaSach = await getCollection("sach");
  return tatCaSach.map((sach) => ({
    params: { slug: sach.id },
    props: { sach },
  }));
}

const { sach } = Astro.props;
const { Content } = await render(sach);
---

<BoCucMacDinh tieuDeTrang={sach.data.tieu_de} moTaTrang={sach.data.mo_ta_ngan} anhTrang={sach.data.anh_bia}>
  <section class="border-b py-20" style="border-color:var(--border)">
    <div class="container mx-auto max-w-6xl px-7 grid gap-11 grid-cols-1 sm:grid-cols-[220px_1fr] items-start">
      <div class="border rounded-sm overflow-hidden" style="aspect-ratio:3/4;background:var(--bg-noi);border-color:var(--border)">
        <img class="w-full h-full object-cover" src={sach.data.anh_bia} alt="" />
      </div>
      <div>
        <h1>{sach.data.tieu_de}</h1>
        <p class="text-[1rem] -mt-1.5 mb-3.5" style="color:var(--text-mo)">
          {sach.data.tac_gia}
          {sach.data.nam_xuat_ban ? ` · ${sach.data.nam_xuat_ban}` : ""}
        </p>
        <p class="text-[1.1rem] max-w-[56ch]" style="color:var(--text-mo)">{sach.data.mo_ta_ngan}</p>
        <ul class="flex flex-wrap gap-1.5 list-none m-0 p-0 mt-3.5">
          {
            sach.data.the_loai.map((tl) => (
              <li class="text-[0.78rem] border rounded-full px-2.5 py-0.5" style="border-color:var(--border);color:var(--text-mo)">
                {tl}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto max-w-6xl px-7 van-ban-dai">
      <Content />

      <div class="flex flex-wrap items-center gap-5 mt-11 pt-7 border-t" style="border-color:var(--border)">
        <span class="text-[1.15rem] font-semibold" style="color:var(--text)">{sach.data.gia || "Miễn phí"}</span>
        {
          sach.data.dinh_dang.length > 0 && (
            <span class="text-[0.9rem]" style="color:var(--text-mo)">
              Định dạng: {sach.data.dinh_dang.join(", ")}
            </span>
          )
        }
        {
          sach.data.link_mua && (
            <a
              class="nut inline-flex items-center gap-1.5 border rounded-sm px-4 py-2 text-[0.9rem] no-underline ml-auto"
              style="border-color:var(--border);color:var(--text)"
              href={sach.data.link_mua}
              target="_blank"
              rel="noopener"
            >
              {sach.data.gia ? "Mua sách" : "Đọc ngay"}
            </a>
          )
        }
      </div>
    </div>
  </section>
</BoCucMacDinh>
