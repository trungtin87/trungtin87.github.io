---
// src/pages/bai-viet/index.astro — Danh sách tất cả bài viết
import { getCollection } from "astro:content";
import BoCucMacDinh from "../../bo_cuc/BoCucMacDinh.astro";
import TheBaiViet from "../../thanh_phan/TheBaiViet.astro";

const tatCaBaiViet = (await getCollection("bai_viet", ({ data }) => !data.nhap)).sort(
  (a, b) => b.data.ngay.valueOf() - a.data.ngay.valueOf()
);
---

<BoCucMacDinh tieuDeTrang="Tất cả bài viết">
  <section class="border-b py-20" style="border-color:var(--border)">
    <div class="container mx-auto max-w-6xl px-7">
      <p class="uppercase tracking-[0.14em] text-[0.78rem] mb-3" style="color:var(--text-mo)">Bài viết</p>
      <h1>Tất cả bài viết</h1>
      <p class="text-[1.1rem] max-w-[56ch]" style="color:var(--text-mo)">
        Ghi chép kỹ thuật và triết học — nơi Âm Dương, Vô vi và mã nguồn gặp nhau.
      </p>
    </div>
  </section>
  <section class="py-20">
    <div class="container mx-auto max-w-6xl px-7">
      <div class="grid gap-11 gap-x-7 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        {tatCaBaiViet.map((bai) => <TheBaiViet bai={bai} />)}
      </div>
    </div>
  </section>
</BoCucMacDinh>
