---
// src/pages/bai-viet/[slug].astro — Trang chi tiết 1 bài viết
// [slug] trong tên file nghĩa là Astro sẽ sinh ra một trang riêng cho MỖI
// bài viết, với đường dẫn /bai-viet/ten-file-markdown.
import { getCollection, render } from "astro:content";
import BoCucBaiViet from "../../bo_cuc/BoCucBaiViet.astro";
import { cauHinh } from "../../cau_hinh/trang_web";

export async function getStaticPaths() {
  const tatCaBaiViet = await getCollection("bai_viet", ({ data }) => !data.nhap);
  return tatCaBaiViet.map((bai) => ({
    params: { slug: bai.id },
    props: { bai },
  }));
}

const { bai } = Astro.props;
const { Content, headings } = await render(bai);

// Tính thời gian đọc: đếm số từ trong nội dung gốc rồi chia cho tốc độ đọc
// trung bình đã cấu hình (so_tu_moi_phut_doc).
const soTu = bai.body?.trim().split(/\s+/).length ?? 0;
const thoiGianDoc = Math.max(1, Math.round(soTu / cauHinh.so_tu_moi_phut_doc));

// Bài liên quan: cùng danh mục hoặc có chung ít nhất 1 tag, tối đa 3 bài.
const tatCaBaiViet = await getCollection("bai_viet", ({ data }) => !data.nhap);
const baiLienQuan = tatCaBaiViet
  .filter((b) => b.id !== bai.id)
  .filter(
    (b) =>
      b.data.danh_muc === bai.data.danh_muc ||
      b.data.tags.some((tag) => bai.data.tags.includes(tag))
  )
  .slice(0, 3);
---

<BoCucBaiViet baiViet={bai} thoiGianDoc={thoiGianDoc} danhSachTieuDeMuc={headings} baiLienQuan={baiLienQuan}>
  <Content />
</BoCucBaiViet>
