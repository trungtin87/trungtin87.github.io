---
// src/pages/thu-vien.astro
import BoCucMacDinh from "../bo_cuc/BoCucMacDinh.astro";

const cacTab = [
  { loai: "all", ten: "Tất cả" },
  { loai: "doc", ten: "Tài liệu" },
  { loai: "pdf", ten: "PDF" },
  { loai: "book", ten: "Sách" },
  { loai: "code", ten: "Mã nguồn" },
  { loai: "note", ten: "Ghi chú" },
];

// Trong dự án thật, danh sách này nên lấy từ một content collection riêng
// (ví dụ src/content/thu_vien/*.md) thay vì viết cứng ở đây — cách làm
// giống hệt bai_viet và du_an đã có, chỉ cần thêm 1 schema mới.
const cacMucThuVien = [
  {
    loai: "doc",
    tenLoai: "Tài liệu",
    tieuDe: "Sổ tay quy ước viết mã cá nhân",
    moTa: "Tập hợp các quy ước đặt tên, cấu trúc thư mục và nguyên tắc review mà tôi tự áp dụng cho các dự án riêng.",
    nhan: "Xem tài liệu →",
  },
  {
    loai: "pdf",
    tenLoai: "PDF",
    tieuDe: 'Ghi chú đọc "Đạo Đức Kinh"',
    moTa: "Bản tóm lược 81 chương kèm chú giải cá nhân, đối chiếu với các ứng dụng trong công việc kỹ thuật.",
    nhan: "Tải PDF →",
  },
  {
    loai: "book",
    tenLoai: "Sách",
    tieuDe: "Trang Tử — Nam Hoa Kinh (bản dịch tham khảo)",
    moTa: "Danh sách các bản dịch tiếng Việt tôi khuyên đọc, kèm nhận xét ngắn về từng bản.",
    nhan: "Xem chi tiết →",
  },
  {
    loai: "code",
    tenLoai: "Mã nguồn",
    tieuDe: "Bộ khung trang tĩnh tối giản",
    moTa: "Mã nguồn khung sườn dùng để dựng nhanh các trang tĩnh cá nhân — HTML/CSS/JS thuần, không phụ thuộc.",
    nhan: "Xem trên GitHub →",
  },
  {
    loai: "note",
    tenLoai: "Ghi chú",
    tieuDe: "Ghi chú vận hành hệ thống nhỏ gọn",
    moTa: "Những điều rút ra khi tự vận hành hạ tầng cho các dự án cá nhân, không cần đội DevOps.",
    nhan: "Đọc ghi chú →",
  },
  {
    loai: "doc",
    tenLoai: "Tài liệu",
    tieuDe: "Bản đồ tri thức cá nhân 2026",
    moTa: "Sơ đồ các chủ đề tôi đang theo đuổi trong năm nay, từ hệ thống phân tán đến triết học phương Đông.",
    nhan: "Xem sơ đồ →",
  },
];
---

<BoCucMacDinh tieuDeTrang="Thư viện">
  <section class="border-b py-20" style="border-color:var(--border)">
    <div class="container mx-auto max-w-6xl px-7">
      <p class="uppercase tracking-[0.14em] text-[0.78rem] mb-3" style="color:var(--text-mo)">Thư viện</p>
      <h1>Thư viện</h1>
      <p class="text-[1.1rem] max-w-[56ch]" style="color:var(--text-mo)">
        Nơi lưu trữ tài liệu, sách, mã nguồn và ghi chú — những thứ đáng giữ lại lâu dài.
      </p>
    </div>
  </section>
  <section class="py-20">
    <div class="container mx-auto max-w-6xl px-7">
      <div class="flex flex-wrap gap-2 mb-11" role="tablist" aria-label="Lọc theo loại tài liệu">
        {
          cacTab.map((tab, chiSo) => (
            <button
              class="nut-tab-thu-vien rounded-full border px-4 py-1.5 text-[0.88rem] cursor-pointer"
              style="border-color:var(--border);color:var(--text-mo);background:none"
              data-tab-thu-vien={tab.loai}
              aria-pressed={chiSo === 0 ? "true" : "false"}
              type="button"
            >
              {tab.ten}
            </button>
          ))
        }
      </div>

      <div class="grid gap-7" style="grid-template-columns:repeat(auto-fill,minmax(260px,1fr))">
        {
          cacMucThuVien.map((muc) => (
            <div class="border rounded-sm p-7 flex flex-col gap-2" style="border-color:var(--border)" data-muc-thu-vien={muc.loai}>
              <span class="uppercase tracking-[0.08em] text-[0.72rem]" style="color:var(--text-mo)">
                {muc.tenLoai}
              </span>
              <h3 class="text-[1rem] mb-0">{muc.tieuDe}</h3>
              <p class="text-[0.9rem]" style="color:var(--text-mo)">{muc.moTa}</p>
              <a class="mt-auto text-[0.88rem]" href="#">{muc.nhan}</a>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BoCucMacDinh>
