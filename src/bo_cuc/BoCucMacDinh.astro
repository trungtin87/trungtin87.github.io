---
// src/bo_cuc/BoCucMacDinh.astro
// Khung HTML gốc dùng cho MỌI trang: thẻ <head> đầy đủ SEO, header, main,
// footer. Tương đương _bocuctrang/trangmacdinh.html của bản gốc. Mọi trang
// khác (index, bai-viet, du-an, ...) đều "mặc lên người" bố cục này.
import DauTrang from "../thanh_phan/DauTrang.astro";
import ChanTrang from "../thanh_phan/ChanTrang.astro";
import BangTimKiem from "../thanh_phan/BangTimKiem.astro";
import { cauHinh } from "../cau_hinh/trang_web";
import { LOGO_FAVICON_32, LOGO_APPLE_TOUCH_ICON } from "../cau_hinh/logo_base64";
import "../styles/toan_cuc.css";

interface Props {
  tieuDeTrang: string;
  moTaTrang?: string;
  anhTrang?: string;
}
const { tieuDeTrang, moTaTrang, anhTrang } = Astro.props;
const moTaThucTe = moTaTrang ?? cauHinh.mo_ta;
const anhThucTe = anhTrang ?? cauHinh.anh_mac_dinh;
const urlDayDu = new URL(Astro.url.pathname, cauHinh.url).toString();
---

<!doctype html>
<html lang={cauHinh.ngon_ngu}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{tieuDeTrang} · {cauHinh.ten_trangweb}</title>
    <meta name="description" content={moTaThucTe} />
    <meta
      name="keywords"
      content={`${cauHinh.ten_trangweb}, ${cauHinh.bi_danh}, Đạo giáo, Vô vi, Âm Dương, Tự nhiên, blog kỹ thuật, thư phòng số, ${cauHinh.tac_gia}`}
    />
    <meta name="author" content={cauHinh.tac_gia} />
    <!-- Favicon nhúng base64 (logo âm dương) — không dùng file ảnh riêng nữa -->
    <link rel="icon" type="image/png" sizes="32x32" href={LOGO_FAVICON_32} />
    <link rel="apple-touch-icon" href={LOGO_APPLE_TOUCH_ICON} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content={cauHinh.mau_giao_dien} />

    <!-- Thẻ SEO / chia sẻ mạng xã hội (Open Graph + Twitter Card) -->
    <meta property="og:title" content={tieuDeTrang} />
    <meta property="og:description" content={moTaThucTe} />
    <meta property="og:image" content={new URL(anhThucTe, cauHinh.url).toString()} />
    <meta property="og:url" content={urlDayDu} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={cauHinh.ten_trangweb} />
    <meta property="og:locale" content="vi_VN" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tieuDeTrang} />
    <meta name="twitter:description" content={moTaThucTe} />
    <meta name="twitter:image" content={new URL(anhThucTe, cauHinh.url).toString()} />

    <link rel="alternate" type="application/rss+xml" title={`${cauHinh.ten_trangweb} — RSS`} href="/rss.xml" />

    <script is:inline>
      // Áp dụng theme đã lưu TRƯỚC khi trang vẽ ra, để tránh hiện tượng
      // "nháy" từ sáng sang tối (FOUC) khi tải lại trang.
      (function () {
        var theme = localStorage.getItem("hktq-theme");
        if (theme) document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: cauHinh.ten_trangweb,
      alternateName: cauHinh.bi_danh,
      url: cauHinh.url + "/",
      author: { "@type": "Person", name: cauHinh.tac_gia },
      description: cauHinh.mo_ta,
    })} />
  </head>
  <body>
    <div class="site flex flex-col min-h-screen">
      <DauTrang />
      <BangTimKiem />

      <main id="noi-dung-chinh" class="flex-1">
        <slot />
      </main>

      <ChanTrang />
    </div>
    <script>
      import "../scripts/tuong_tac_client.js";
    </script>
  </body>
</html>
