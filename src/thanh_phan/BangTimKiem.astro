---
// src/thanh_phan/BangTimKiem.astro
// Gộp 2 thứ phụ trợ điều hướng, giống _thanhphantrang/thanhdieuhuong.html
// bản gốc: (1) bảng tìm kiếm nổi mở bằng Ctrl/Cmd+K, (2) nút "về đầu trang".
// Dữ liệu tìm kiếm được nạp từ /du-lieu-tim-kiem.json (sinh tự động lúc build,
// xem src/pages/du-lieu-tim-kiem.json.ts).
---

<div
  class="bang-tim-kiem hop-tim-kiem-khung fixed inset-0 items-start justify-center px-7 pb-7 z-[200]"
  style="padding-top:10vh"
  data-bang-tim-kiem
  role="dialog"
  aria-modal="true"
  aria-label="Tìm kiếm"
>
  <div class="w-full max-w-[640px] max-h-[70vh] overflow-auto p-7 border rounded-sm" style="background:var(--bg);border-color:var(--border)">
    <button class="nut float-right border rounded-sm px-3.5 py-1.5 text-[0.88rem] cursor-pointer" style="border-color:var(--border);color:var(--text);background:none" data-dong-tim-kiem type="button">
      Đóng ✕
    </button>
    <label class="sr-only" for="o-nhap-tim-kiem">Tìm kiếm bài viết</label>
    <input
      id="o-nhap-tim-kiem"
      class="w-full text-[1.1rem] bg-transparent border-0 border-b pb-3.5 pt-1.5 mb-4"
      style="border-color:var(--border);color:var(--text)"
      data-o-nhap-tim-kiem
      type="text"
      placeholder="Tìm bài viết…"
      autocomplete="off"
    />
    <ul class="flex flex-col gap-0.5 list-none m-0 p-0" data-ket-qua-tim-kiem></ul>
  </div>
</div>

<button
  class="nut-ve-dau-trang fixed right-7 bottom-7 w-[42px] h-[42px] rounded-full border cursor-pointer flex items-center justify-center z-40"
  style="border-color:var(--border);background:var(--bg);color:var(--text)"
  data-ve-dau-trang
  type="button"
  aria-label="Về đầu trang"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
    <line x1="12" y1="19" x2="12" y2="5"></line>
    <polyline points="5 12 12 5 19 12"></polyline>
  </svg>
</button>
