---
// src/thanh_phan/TheBaiViet.astro
// Một "thẻ" bài viết dạng lưới ảnh + tiêu đề + mô tả ngắn. Dùng ở trang chủ,
// trang danh sách bài viết, và khối "bài liên quan".
import type { CollectionEntry } from "astro:content";

interface Props {
  bai: CollectionEntry<"bai_viet">;
}
const { bai } = Astro.props;
const ngayHienThi = new Date(bai.data.ngay).toLocaleDateString("vi-VN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a class="block no-underline" style="color:var(--text)" href={`/bai-viet/${bai.id}`}>
  <div
    class="mb-3.5 overflow-hidden border rounded-sm"
    style="aspect-ratio:4/3;border-color:var(--border);background:var(--bg-noi)"
  >
    <img class="w-full h-full object-cover" src={bai.data.anh_bia} alt="" width="400" height="300" loading="lazy" />
  </div>
  <div class="flex items-center gap-2.5 text-[0.82rem] mb-1.5" style="color:var(--text-mo)">
    <span class="border rounded-full px-2.5 py-0.5" style="border-color:var(--border)">{bai.data.danh_muc}</span>
    <span>{ngayHienThi}</span>
  </div>
  <h3 class="mb-1.5 text-[1.08rem]">{bai.data.tieu_de}</h3>
  <p class="m-0 text-[0.95rem]" style="color:var(--text-mo)">{bai.data.mo_ta}</p>
</a>
