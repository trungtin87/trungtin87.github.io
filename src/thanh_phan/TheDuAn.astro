---
// src/thanh_phan/TheDuAn.astro
// Một "thẻ" dự án: ảnh đại diện, tên, mô tả ngắn, danh sách công nghệ,
// và nút "Chi tiết" dẫn tới trang riêng của dự án.
import type { CollectionEntry } from "astro:content";

interface Props {
  duAn: CollectionEntry<"du_an">;
}
const { duAn } = Astro.props;
---

<div class="border rounded-sm overflow-hidden flex flex-col" style="border-color:var(--border)">
  <div class="border-b overflow-hidden" style="aspect-ratio:16/9;background:var(--bg-noi);border-color:var(--border)">
    <img class="w-full h-full object-cover" src={duAn.data.anh_dai_dien} alt="" loading="lazy" />
  </div>
  <div class="p-7 flex flex-col gap-2.5 flex-1">
    <h3 class="text-[1.2rem] m-0">{duAn.data.tieu_de}</h3>
    <p class="m-0 text-[0.95rem]" style="color:var(--text-mo)">{duAn.data.mo_ta_ngan}</p>
    <ul class="flex flex-wrap gap-1.5 list-none m-0 p-0">
      {
        duAn.data.cong_nghe.map((cn) => (
          <li class="text-[0.78rem] border rounded-full px-2.5 py-0.5" style="border-color:var(--border);color:var(--text-mo)">
            {cn}
          </li>
        ))
      }
    </ul>
    <div class="flex gap-2.5 mt-auto pt-1.5">
      <a
        class="nut inline-flex items-center gap-1.5 border rounded-sm px-3.5 py-1.5 text-[0.88rem] no-underline"
        style="border-color:var(--border);color:var(--text)"
        href={`/du-an/${duAn.id}`}
      >
        Chi tiết
      </a>
    </div>
  </div>
</div>
