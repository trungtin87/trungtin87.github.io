---
// src/thanh_phan/ChanTrang.astro
// Chân trang: logo nhỏ + tên tác giả, khẩu hiệu, và các liên kết phụ.
import { cauHinh } from "../cau_hinh/trang_web";
import { LOGO_HEADER } from "../cau_hinh/logo_base64";
const namNay = new Date().getFullYear();
---

<footer class="border-t py-12" style="border-color:var(--border)">
  <div class="container mx-auto max-w-6xl px-7 flex flex-wrap items-center justify-between gap-7">
    <div class="flex items-center gap-2.5 text-[0.88rem]" style="color:var(--text-mo)">
      <img class="w-5 h-5 rounded-full" src={LOGO_HEADER} alt="" width="26" height="26" />
      <span>{cauHinh.tac_gia} · © {namNay} {cauHinh.ten_trangweb}</span>
    </div>
    <p class="italic text-[0.88rem] m-0" style="color:var(--text-mo)">"{cauHinh.khau_hieu}"</p>
    <ul class="flex gap-4 list-none m-0 p-0">
      <li><a class="text-[0.88rem] no-underline" style="color:var(--text-mo)" href="/rss.xml">RSS</a></li>
      <li><a class="text-[0.88rem] no-underline" style="color:var(--text-mo)" href="/sitemap-index.xml">Sitemap</a></li>
      <li><a class="text-[0.88rem] no-underline" style="color:var(--text-mo)" href="/lien-he">Liên hệ</a></li>
    </ul>
  </div>
</footer>
