---
// src/thanh_phan/TheSanPham.astro
// Một "thẻ" sản phẩm trong Cửa hàng: ảnh, tên, mô tả ngắn, giá (kèm giá
// gốc nếu đang giảm giá), trạng thái còn/hết hàng, nút mua.
import type { CollectionEntry } from "astro:content";

interface Props {
  sanPham: CollectionEntry<"cua_hang">;
}
const { sanPham } = Astro.props;
---

<div class="border rounded-sm overflow-hidden flex flex-col" style="border-color:var(--border)">
  <div class="relative border-b overflow-hidden" style="aspect-ratio:1/1;background:var(--bg-noi);border-color:var(--border)">
    <img class="w-full h-full object-cover" src={sanPham.data.anh_san_pham} alt="" loading="lazy" />
    {
      !sanPham.data.con_hang && (
        <span
          class="absolute top-2.5 right-2.5 text-[0.75rem] rounded-full px-2.5 py-0.5"
          style="background:var(--bg);color:var(--text-mo);border:1px solid var(--border)"
        >
          Hết hàng
        </span>
      )
    }
  </div>
  <div class="p-7 flex flex-col gap-2.5 flex-1">
    <h3 class="text-[1.2rem] m-0">{sanPham.data.ten_san_pham}</h3>
    <p class="m-0 text-[0.95rem]" style="color:var(--text-mo)">{sanPham.data.mo_ta_ngan}</p>
    <ul class="flex flex-wrap gap-1.5 list-none m-0 p-0">
      {
        sanPham.data.danh_muc.map((dm) => (
          <li class="text-[0.78rem] border rounded-full px-2.5 py-0.5" style="border-color:var(--border);color:var(--text-mo)">
            {dm}
          </li>
        ))
      }
    </ul>
    <div class="flex items-center justify-between gap-2.5 mt-auto pt-1.5">
      <span class="flex items-baseline gap-2">
        <span class="text-[1rem] font-semibold" style="color:var(--text)">{sanPham.data.gia}</span>
        {
          sanPham.data.gia_goc && (
            <span class="text-[0.85rem] line-through" style="color:var(--text-mo)">
              {sanPham.data.gia_goc}
            </span>
          )
        }
      </span>
      <a
        class="nut inline-flex items-center gap-1.5 border rounded-sm px-3.5 py-1.5 text-[0.88rem] no-underline"
        style={
          sanPham.data.con_hang
            ? "border-color:var(--border);color:var(--text)"
            : "border-color:var(--border);color:var(--text-mo);pointer-events:none;opacity:0.6"
        }
        href={`/cua-hang/${sanPham.id}`}
      >
        {sanPham.data.con_hang ? "Xem sản phẩm" : "Hết hàng"}
      </a>
    </div>
  </div>
</div>
