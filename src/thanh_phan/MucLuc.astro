---
// src/thanh_phan/MucLuc.astro
// Mục lục bài viết, sinh từ danh sách "headings" (thẻ h2/h3) mà Astro tự
// trích xuất khi render Markdown — không cần quét lại bằng JavaScript như
// bản gốc. Việc tô đậm mục đang đọc khi cuộn vẫn cần JS phía trình duyệt,
// xem src/scripts/tuong_tac_client.js.
import type { MarkdownHeading } from "astro";

interface Props {
  danhSachTieuDeMuc: MarkdownHeading[];
}
const { danhSachTieuDeMuc } = Astro.props;
const cacMucChinh = danhSachTieuDeMuc.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  cacMucChinh.length > 0 && (
    <aside class="muc-luc sticky text-[0.88rem] border-l pl-3.5" style="top:6rem;border-color:var(--border)" data-muc-luc aria-label="Mục lục bài viết">
      <h2 class="uppercase tracking-[0.1em] text-[0.78rem] mb-3" style="color:var(--text-mo)">
        Mục lục
      </h2>
      <ol class="list-none m-0 p-0 flex flex-col gap-1.5">
        {cacMucChinh.map((muc) => (
          <li class={muc.depth === 3 ? "pl-3.5" : ""}>
            <a class="no-underline" style="color:var(--text-mo)" href={`#${muc.slug}`} data-lien-ket-muc-luc={muc.slug}>
              {muc.text}
            </a>
          </li>
        ))}
      </ol>
    </aside>
  )
}
